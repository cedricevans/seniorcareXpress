# Copy this file to .env and fill in your values

# Local dev
VITE_POCKETBASE_URL=http://localhost:8090
VITE_API_URL=http://localhost:3001

# Production — PocketHost (free managed PocketBase hosting)
# VITE_POCKETBASE_URL=https://your-instance.pockethost.io
# VITE_API_URL=https://your-api.railway.app

# Production — Self-hosted VPS
# VITE_POCKETBASE_URL=https://yourdomain.com:8090
# VITE_API_URL=https://yourdomain.com:3001
